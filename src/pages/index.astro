  <div class="divider"></div>

  <!-- BLOG PREVIEW -->
  <section class="blog-preview">
    <div class="blog-header">
      <div>
        <div class="section-label">Writing</div>
        <h2 class="section-heading">Recent posts</h2>
      </div>
      <a href="/blog" class="view-all">View all posts →</a>
    </div>
    <div class="blog-list">
      {recentPosts.map((post) => (
        <a href={`/blog/${post.id}`} class="blog-row">
          <span class="blog-date">{timeAgo(post.data.date)} | {Math.ceil(post.body.split(/\s+/).length / 200)} min read</span>
          <div class="blog-text">
            <div class="blog-title">{post.data.title}</div>
            <div class="blog-desc">{post.data.description}</div>
          </div>
          <div class="blog-tags">
            {post.data.tags.slice(0, 2).map((tag) => (
              <span class="blog-tag">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </section>

  <div class="divider"></div>

  <!-- PROCESS -->
  <section class="process" id="process">
    <div class="section-label">Process</div>
    <h2 class="section-heading">How I work</h2>
    <div class="process-grid">
      <div class="process-step">
        <div class="step-num">01 &mdash;</div>
        <h4>Discovery</h4>
        <p>Deep-dive into your business goals, technical requirements, and existing infrastructure to map the optimal path forward.</p>
      </div>
      <div class="process-step">
        <div class="step-num">02 &mdash;</div>
        <h4>Architecture</h4>
        <p>Design system architecture with clear milestones, tech stack decisions, and a roadmap that accounts for scale.</p>
      </div>
      <div class="process-step">
        <div class="step-num">03 &mdash;</div>
        <h4>Build</h4>
        <p>Iterative development with weekly demos, transparent communication, and production-grade code from day one.</p>
      </div>
      <div class="process-step">
        <div class="step-num">04 &mdash;</div>
        <h4>Launch &amp; Scale</h4>
        <p>Deploy with confidence — monitoring, documentation, and ongoing support to ensure your system thrives.</p>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- CTA -->
  <CTA />

  <!-- FOOTER -->
  <Footer />

</div>

</Layout>
