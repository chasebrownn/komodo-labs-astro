---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CTA from '../components/CTA.astro';
import { getCollection } from 'astro:content';

const recentPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

function timeAgo(date: Date) {
  const utcDate = Date.UTC(date.getUTCFullYear(), date.getUTCMonth(), date.getUTCDate());
  const days = Math.floor((Date.now() - utcDate) / (1000 * 60 * 60 * 24));
  if (days === 0) return 'Today';
  if (days < 30) return `${days}d ago`;
  const months = Math.floor(days / 30);
  if (months < 12) return `${months}mo ago`;
  const years = Math.floor(days / 365);
  return `${years}y ago`;
}
---

<Layout
  title="Chase Brown — Komodo Labs"
  description="AI integration, blockchain architecture, and custom automations — I help companies ship smarter, faster, and at scale."
>
<style>

  /* ═══ NAV ═══ */
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 0;
    border-bottom: 1px solid var(--border);
    animation: fadeDown 0.5s ease both;
  }

  .nav-logo {
    font-family: var(--font-mono);
    font-size: 15px;
    font-weight: 600;
    color: var(--white);
    letter-spacing: 1px;
  }

  .nav-logo span { color: var(--neon); }

  .nav-links {
    display: flex;
    gap: 40px;
    list-style: none;
  }

  .nav-links a {
    font-size: 14px;
    font-weight: 400;
    color: var(--gray-400);
    transition: color 0.25s;
  }

  .nav-links a:hover { color: var(--white); }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .nav-status {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--gray-500);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .nav-status .dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--neon);
    box-shadow: 0 0 8px var(--neon-glow);
    animation: pulse 2.5s ease infinite;
  }

  .nav-cta-btn {
    font-size: 13px;
    font-weight: 500;
    padding: 9px 20px;
    border-radius: 8px;
    background: var(--white);
    color: var(--black);
    transition: all 0.25s;
  }

  .nav-cta-btn:hover {
    background: var(--neon);
    color: var(--black);
  }

  /* ═══ HERO ═══ */
  .hero {
    padding: 120px 0 100px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 64px;
  }

  .hero-content {
    text-align: left;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--neon);
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 36px;
    opacity: 0;
    animation: fadeUp 0.6s ease 0.15s both;
  }

  .hero-badge::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--neon);
    animation: pulse 2.5s ease infinite;
  }

  .hero h1 {
    font-size: clamp(44px, 6vw, 72px);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -2px;
    margin-bottom: 28px;
    opacity: 0;
    animation: fadeUp 0.6s ease 0.25s both;
  }

  .hero h1 .thin {
    font-weight: 300;
    color: var(--gray-400);
  }

  .hero h1 .neon {
    color: var(--neon);
  }

  .hero-desc {
    font-size: 18px;
    font-weight: 300;
    color: var(--gray-300);
    line-height: 1.7;
    max-width: 560px;
    margin: 0 0 44px;
    opacity: 0;
    animation: fadeUp 0.6s ease 0.4s both;
  }

  .hero-actions {
    display: flex;
    justify-content: flex-start;
    gap: 14px;
    opacity: 0;
    animation: fadeUp 0.6s ease 0.55s both;
  }

  .btn {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 500;
    padding: 14px 32px;
    border-radius: 10px;
    border: none;
    cursor: pointer;
    transition: all 0.3s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
  }

  .btn-primary {
    background: var(--neon);
    color: var(--black);
    font-weight: 600;
  }

  .btn-primary:hover {
    box-shadow: 0 0 32px var(--neon-glow);
    transform: translateY(-2px);
  }

  .btn-secondary {
    background: var(--card);
    color: var(--gray-200);
    border: 1px solid var(--border);
  }

  .btn-secondary:hover {
    border-color: var(--border-hi);
    background: var(--card-hover);
    color: var(--white);
  }

  /* ═══ TERMINAL ═══ */
  .terminal-wrap {
    opacity: 0;
    animation: fadeUp 0.7s ease 0.6s both;
  }

  .terminal {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 13px 16px;
    border-bottom: 1px solid var(--border);
  }

  .terminal-dot { width: 10px; height: 10px; border-radius: 50%; }
  .terminal-dot.r { background: #ff5f57; }
  .terminal-dot.y { background: #ffbd2e; }
  .terminal-dot.g { background: #28c840; }

  .terminal-title {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--gray-600);
    margin-left: 8px;
  }

  .terminal-body {
    padding: 18px 20px;
    font-family: var(--font-mono);
    font-size: 12.5px;
    line-height: 2;
  }

  .tl { color: var(--gray-400); }
  .tl .p { color: var(--gray-500); }
  .tl .cmd { color: var(--white); }
  .tl .flag { color: var(--gray-300); }
  .tl .key { color: var(--neon); }
  .tl .val { color: var(--gray-300); }
  .tl .status { color: var(--neon); }

  .cursor {
    display: inline-block;
    width: 8px; height: 15px;
    background: var(--neon);
    vertical-align: text-bottom;
    animation: blink 1s step-end infinite;
  }

  /* ═══ DIVIDER ═══ */
  .divider {
    height: 1px;
    background: var(--border);
    margin: 0;
  }

  /* ═══ SECTION COMMON ═══ */
  .section-label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--gray-500);
    letter-spacing: 2.5px;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .section-heading {
    font-size: 36px;
    font-weight: 700;
    letter-spacing: -1px;
    margin-bottom: 52px;
  }

  /* ═══ ABOUT PREVIEW ═══ */
  .about-preview {
    padding: 100px 0;
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 64px;
    align-items: center;
    opacity: 0;
    animation: fadeUp 0.5s ease 0.15s both;
  }

  .about-photo {
    width: 100%;
    aspect-ratio: 3 / 4;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid var(--border);
    flex-shrink: 0;
  }

  .about-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
  }

  .about-body { }

  .about-body h2 {
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.8px;
    margin-bottom: 20px;
  }

  .about-body p {
    font-size: 15.5px;
    font-weight: 300;
    color: var(--gray-300);
    line-height: 1.8;
    margin-bottom: 14px;
  }

  .about-body p strong {
    color: var(--white);
    font-weight: 500;
  }

  .about-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 12px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--neon);
    text-decoration: none;
    letter-spacing: 1px;
    transition: opacity 0.2s;
  }

  .about-link:hover { opacity: 0.75; }

  @media (max-width: 768px) {
    .about-preview {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .about-photo {
      aspect-ratio: 4 / 3;
      max-width: 200px;
    }
  }

  /* ═══ SERVICES ═══ */
  .services { padding: 100px 0; }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .service-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 36px 30px;
    transition: all 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    position: relative;
    opacity: 0;
    animation: fadeUp 0.5s ease both;
  }

  .service-card:nth-child(1) { animation-delay: 0.05s; }
  .service-card:nth-child(2) { animation-delay: 0.12s; }
  .service-card:nth-child(3) { animation-delay: 0.19s; }

  .service-card:hover {
    border-color: var(--border-hi);
    background: var(--card);
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.4);
  }

  .service-icon {
    width: 44px; height: 44px;
    border-radius: 10px;
    background: var(--neon-dim);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    transition: background 0.3s;
  }

  .service-card:hover .service-icon { background: var(--neon-mid); }

  .service-card h3 {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--white);
  }

  .service-card p {
    font-size: 14px;
    color: var(--gray-400);
    line-height: 1.7;
    margin-bottom: 24px;
    font-weight: 300;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 10.5px;
    padding: 5px 10px;
    border-radius: 6px;
    background: var(--bg);
    color: var(--gray-500);
    border: 1px solid var(--border);
    letter-spacing: 0.5px;
    transition: all 0.3s;
  }

  .service-card:hover .tag { color: var(--gray-400); border-color: var(--border-hi); }

  /* ═══ PROJECTS ═══ */
  .projects { padding: 100px 0; }

  .projects-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .project-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 32px;
    transition: all 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    opacity: 0;
    animation: fadeUp 0.5s ease both;
  }

  .project-card:nth-child(1) { animation-delay: 0.05s; }
  .project-card:nth-child(2) { animation-delay: 0.1s; }
  .project-card:nth-child(3) { animation-delay: 0.15s; }
  .project-card:nth-child(4) { animation-delay: 0.2s; }

  .project-card:hover {
    border-color: var(--border-hi);
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.3);
  }

  .project-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 16px;
  }

  .project-type {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--gray-500);
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .badge {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 4px 10px;
    border-radius: 20px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  .badge-live {
    color: var(--neon);
    background: var(--neon-dim);
    border: 1px solid rgba(207,255,4,0.15);
  }

  .badge-done {
    color: var(--gray-300);
    background: rgba(163,163,163,0.08);
    border: 1px solid rgba(163,163,163,0.12);
  }

  .project-card h3 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 10px;
    color: var(--white);
  }

  .project-card p {
    font-size: 13.5px;
    color: var(--gray-400);
    line-height: 1.7;
    margin-bottom: 20px;
    font-weight: 300;
  }

  .tech-tags { display: flex; gap: 6px; flex-wrap: wrap; }

  .tech-tags span {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 4px 8px;
    border-radius: 4px;
    background: var(--bg);
    color: var(--gray-500);
    border: 1px solid var(--border);
  }

  /* ═══ PROCESS ═══ */
  .process { padding: 100px 0; }

  .process-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
  }

  .process-step {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 36px 28px;
    transition: all 0.3s;
    opacity: 0;
    animation: fadeUp 0.5s ease both;
  }

  .process-step:first-child { border-radius: 14px 0 0 14px; }
  .process-step:last-child { border-radius: 0 14px 14px 0; }

  .process-step:nth-child(1) { animation-delay: 0.05s; }
  .process-step:nth-child(2) { animation-delay: 0.1s; }
  .process-step:nth-child(3) { animation-delay: 0.15s; }
  .process-step:nth-child(4) { animation-delay: 0.2s; }

  .process-step:hover { background: var(--card); }

  .step-num {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--neon);
    margin-bottom: 16px;
    letter-spacing: 2px;
  }

  .process-step h4 {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 10px;
    color: var(--white);
  }

  .process-step p {
    font-size: 13px;
    color: var(--gray-400);
    line-height: 1.65;
    font-weight: 300;
  }

  /* ═══ BLOG PREVIEW ═══ */
  .blog-preview { padding: 100px 0; }

  .blog-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 52px;
  }

  .blog-header h2 { margin-bottom: 0; }

  .view-all {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--neon);
    text-decoration: none;
    letter-spacing: 1px;
    white-space: nowrap;
    transition: opacity 0.2s;
  }

  .view-all:hover { opacity: 0.75; }

  .blog-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .blog-row {
    display: grid;
    grid-template-columns: 120px 1fr auto;
    align-items: center;
    gap: 32px;
    padding: 28px 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    transition: background 0.2s;
    opacity: 0;
    animation: fadeUp 0.5s ease both;
  }

  .blog-row:first-child { border-top: 1px solid var(--border); }

  .blog-row:nth-child(1) { animation-delay: 0.05s; }
  .blog-row:nth-child(2) { animation-delay: 0.12s; }
  .blog-row:nth-child(3) { animation-delay: 0.19s; }

  .blog-row:hover .blog-title { color: var(--neon); }

  .blog-date {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--gray-400);
    white-space: nowrap;
  }

  .blog-text { min-width: 0; }

  .blog-title {
    font-size: 16px;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 5px;
    transition: color 0.2s;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .blog-desc {
    font-size: 13px;
    color: var(--gray-400);
    font-weight: 300;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .blog-tags {
    display: flex;
    gap: 6px;
    flex-shrink: 0;
  }

  .blog-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 4px 9px;
    border-radius: 5px;
    background: var(--bg);
    color: var(--gray-400);
    border: 1px solid var(--border);
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .blog-header { align-items: flex-start; flex-direction: column; gap: 12px; }
    .blog-row { grid-template-columns: 1fr; gap: 8px; padding: 20px 0; }
    .blog-tags { display: none; }
    .blog-title { white-space: normal; overflow: visible; text-overflow: unset; }
    .blog-desc { white-space: normal; overflow: visible; text-overflow: unset; }
  }

  /* ═══ FOOTER ═══ */
  .footer {
    padding: 36px 0;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-copy {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--gray-600);
  }

  .footer-links {
    display: flex;
    gap: 28px;
    list-style: none;
  }

  .footer-links a {
    font-size: 13px;
    color: var(--gray-500);
    transition: color 0.25s;
  }

  .footer-links a:hover { color: var(--white); }

  /* ═══ ANIMATIONS ═══ */
  /* ═══ RESPONSIVE ═══ */
  @media (max-width: 1024px) {
    .services-grid { grid-template-columns: 1fr 1fr; }
    .process-grid { grid-template-columns: 1fr 1fr; }
    .process-step:first-child { border-radius: 14px 0 0 0; }
    .process-step:nth-child(2) { border-radius: 0 14px 0 0; }
    .process-step:nth-child(3) { border-radius: 0 0 0 14px; }
    .process-step:last-child { border-radius: 0 0 14px 0; }
  }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .nav-status { display: none; }
    .hero { padding: 80px 0 60px; grid-template-columns: 1fr; gap: 40px; }
    .services-grid { grid-template-columns: 1fr; }
    .projects-grid { grid-template-columns: 1fr; }
    .process-grid { grid-template-columns: 1fr; }
    .process-step,
    .process-step:first-child, .process-step:last-child,
    .process-step:nth-child(2), .process-step:nth-child(3) { border-radius: 14px; }
    .cta-box { padding: 52px 24px; }
    .hero-actions { flex-direction: column; align-items: flex-start; }
    .cta-actions { flex-direction: column; align-items: center; }
    .footer { flex-direction: column; gap: 16px; text-align: center; }
  }
</style>

<div class="wrapper">

  <!-- NAV -->
  <Nav />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-content">
      <div class="hero-badge">Open for projects</div>
      <h1>Hello, I'm Chase.<br><span class="thin">I build</span> <span class="neon">intelligent</span><br><span class="thin">systems.</span></h1>
      <p class="hero-desc">
        AI integration, blockchain architecture, and custom automations — I help companies ship smarter, faster, and at scale.
      </p>
      <div class="hero-actions">
        <a href="#contact" class="btn btn-primary">Start a Project</a>
        <a href="/projects" class="btn btn-secondary">View Work</a>
      </div>
    </div>

    <div class="terminal-wrap">
      <div class="terminal">
        <div class="terminal-bar">
          <span class="terminal-dot r"></span>
          <span class="terminal-dot y"></span>
          <span class="terminal-dot g"></span>
          <span class="terminal-title">chase ~ /projects</span>
        </div>
        <div class="terminal-body">
          <div class="tl"><span class="p">$</span> <span class="cmd">chase</span> <span class="flag">--status</span></div>
          <div class="tl">&nbsp;</div>
          <div class="tl"><span class="key">role</span>     <span class="val">Full-Stack Engineer</span></div>
          <div class="tl"><span class="key">focus</span>    <span class="val">AI · Blockchain · Automation</span></div>
          <div class="tl"><span class="key">exp</span>      <span class="val">8+ years</span></div>
          <div class="tl"><span class="key">location</span> <span class="val">Remote / Worldwide</span></div>
          <div class="tl"><span class="key">status</span>   <span class="status">&#9679; open to work</span></div>
          <div class="tl">&nbsp;</div>
          <div class="tl"><span class="p">$</span> <span class="cursor"></span></div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ABOUT PREVIEW -->
  <div class="about-preview">
    <div class="about-photo">
      <img src="/headshot.jpg" alt="Chase Brown" />
    </div>
    <div class="about-body">
      <div class="section-label">About Me</div>
      <h2>Who I am</h2>
      <p>
        I'm a software engineer and founder with over 8 years of experience designing and deploying production-grade systems across Web3, fintech, and AI. I got my start founding a development shop out of college and have since worked with financial institutions, hedge funds, and high-growth crypto-native teams.
      </p>
      <p>
        Through <strong>Komodo Labs</strong>, I partner with companies to design, build, and scale software — from stablecoin architectures and cross-chain infrastructure to AI-powered workflows and custom automation.
      </p>
      <a href="/about" class="about-link">Read more →</a>
    </div>
  </div>

  <div class="divider"></div>

  <!-- SERVICES -->
  <section class="services" id="services">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:52px;">
      <div>
        <div class="section-label">Services</div>
        <h2 style="font-size:36px;font-weight:700;letter-spacing:-1px;margin-bottom:0;">What I do</h2>
      </div>
      <a href="/services" class="view-all">All services →</a>
    </div>
    <div class="services-grid">
      <div class="service-card">
        <div class="service-icon">
