---
import projects from '../data/projects.json';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const statusConfig = {
  live:        { label: "Live",        color: "#CFFF04" },
  "in-progress": { label: "In Progress", color: "#f59e0b" },
  complete:    { label: "Complete",    color: "#737373" },
};
---

<Layout
  title="Projects — Komodo Labs"
  description="A showcase of projects across Web3, AI, and automation — smart contracts, stablecoins, AI agents, and more."
>
<style>

  /* PAGE HEADER */
  .page-header {
    padding: 72px 0 56px;
    opacity: 0;
    animation: fadeUp 0.5s ease 0.1s both;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--gray-400);
    letter-spacing: 2.5px;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .page-header h1 {
    font-size: 40px;
    font-weight: 700;
    letter-spacing: -1px;
  }

  /* TABLE */
  .projects-table {
    width: 100%;
    border-collapse: collapse;
    opacity: 0;
    animation: fadeUp 0.5s ease 0.2s both;
  }

  .projects-table thead tr {
    border-bottom: 1px solid var(--border);
  }

  .projects-table th {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--gray-400);
    letter-spacing: 2px;
    text-transform: uppercase;
    font-weight: 400;
    text-align: left;
    padding: 0 16px 16px;
  }

  .projects-table th:first-child { padding-left: 0; }
  .projects-table th:last-child { padding-right: 0; text-align: right; }

  .projects-table tbody tr {
    border-bottom: 1px solid var(--border);
    transition: background 0.2s;
  }

  .projects-table tbody tr:hover { background: var(--surface); }

  .projects-table td {
    padding: 22px 16px;
    vertical-align: middle;
  }

  .projects-table td:first-child { padding-left: 0; }
  .projects-table td:last-child { padding-right: 0; text-align: right; }

  /* Cells */
  .project-name {
    font-size: 15px;
    font-weight: 600;
    color: var(--white);
    white-space: nowrap;
  }

  .project-desc {
    font-size: 13.5px;
    color: var(--gray-300);
    font-weight: 300;
    line-height: 1.6;
    max-width: 380px;
  }

  .labels {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .label {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 4px 9px;
    border-radius: 5px;
    background: var(--bg);
    color: var(--gray-300);
    border: 1px solid var(--border);
    white-space: nowrap;
  }

  .status {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-mono);
    font-size: 11.5px;
    white-space: nowrap;
  }

  .status-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .status-dot.live {
    animation: pulse 2.5s ease infinite;
  }

  .links {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 12px;
  }

  .icon-link {
    display: inline-flex;
    align-items: center;
    color: var(--gray-400);
    transition: color 0.2s;
  }

  .icon-link:hover { color: var(--white); }

  @media (max-width: 900px) {
    .projects-table,
    .projects-table tbody,
    .projects-table tr,
    .projects-table td { display: block; width: 100%; }

    .projects-table thead { display: none; }

    .projects-table tr {
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 20px;
      margin-bottom: 12px;
      background: var(--surface);
      transition: background 0.2s;
    }

    .projects-table tr:hover { background: var(--card); }

    .projects-table td {
      padding: 0;
      border: none;
      text-align: left;
    }

    .projects-table td:nth-child(1) { margin-bottom: 8px; }
    .projects-table td:nth-child(2) { margin-bottom: 14px; }
    .projects-table td:nth-child(3) { margin-bottom: 12px; }
    .projects-table td:nth-child(4) { margin-bottom: 12px; }

    .project-desc { display: block; }

    .links { justify-content: flex-start; }
  }
</style>

<div class="wrapper">

  <Nav />

  <div class="page-header">
    <div class="section-label">Work</div>
    <h1>Projects</h1>
  </div>

  <table class="projects-table">
    <thead>
      <tr>
        <th>Project</th>
        <th>Description</th>
        <th>Labels</th>
        <th>Status</th>
        <th>Links</th>
      </tr>
    </thead>
    <tbody>
      {projects.map((p) => {
        const s = statusConfig[p.status.toLowerCase()];
        return (
          <tr>
            <td><span class="project-name">{p.name}</span></td>
            <td><span class="project-desc">{p.description}</span></td>
            <td>
              <div class="labels">
                {p.labels.map((l) => <span class="label">{l}</span>)}
              </div>
            </td>
            <td>
              <span class="status">
                {p.status.toLowerCase() === 'live' && <span class="status-dot live" style={`background: ${s.color}; box-shadow: 0 0 6px ${s.color}55`}></span>}
                <span style={`color: ${s.color}`}>{s.label}</span>
              </span>
            </td>
            <td>
              <div class="links">
                {p.repo && (
                  <a href={p.repo} target="_blank" rel="noopener noreferrer" class="icon-link" title="View on GitHub">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>
                  </a>
                )}
                {p.website && (
                  <a href={p.website} target="_blank" rel="noopener noreferrer" class="icon-link" title="Visit website">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                  </a>
                )}
              </div>
            </td>
          </tr>
        );
      })}
    </tbody>
  </table>

  <Footer />

</div>

</Layout>
