---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
}

function timeAgo(date: Date) {
  const utcDate = Date.UTC(date.getUTCFullYear(), date.getUTCMonth(), date.getUTCDate());
  const days = Math.floor((Date.now() - utcDate) / (1000 * 60 * 60 * 24));
  if (days === 0) return 'Today';
  if (days < 30) return `${days}d ago`;
  const months = Math.floor(days / 30);
  if (months < 12) return `${months}mo ago`;
  const years = Math.floor(days / 365);
  return `${years}y ago`;
}

const readingTime = Math.ceil(post.body.split(/\s+/).length / 200);

const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter((p) => p.id !== post.id && p.data.tags.some((t) => post.data.tags.includes(t)))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Layout
  title={`${post.data.title} — Komodo Labs`}
  description={post.data.description}
  image={`/og/${post.id}.png`}
>
<style>
  .post-header {
    padding: 48px 0 52px;
    max-width: 720px;
    opacity: 0;
    animation: fadeUp 0.5s ease 0.1s both;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--gray-500);
    letter-spacing: 2.5px;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .section-label a {
    color: var(--gray-500);
    text-decoration: none;
    transition: color 0.2s;
  }

  .section-label a:hover { color: var(--neon); }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--gray-500);
    text-decoration: none;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-top: 32px;
    transition: color 0.2s;
  }

  .back-link:hover { color: var(--neon); }
  .back-link svg { transition: transform 0.2s; }
  .back-link:hover svg { transform: translateX(-3px); }

  .post-header h1 {
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 800;
    letter-spacing: -1.5px;
    line-height: 1.1;
    margin-bottom: 20px;
  }

  .post-meta {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .post-meta-row {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--gray-400);
  }

  .author {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .author-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--border-hi);
  }

  .author-name {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--gray-400);
    text-decoration: none;
  }

  .author-name:hover {
    color: var(--neon);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 4px 9px;
    border-radius: 5px;
    background: var(--bg);
    color: var(--gray-400);
    border: 1px solid var(--border);
  }

  .divider {
    height: 1px;
    background: var(--border);
    margin-bottom: 56px;
  }

  /* PROSE */
  .prose {
    max-width: 720px;
    margin-bottom: 100px;
    opacity: 0;
    animation: fadeUp 0.5s ease 0.2s both;
  }

  .prose :global(h2) {
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.5px;
    margin: 48px 0 16px;
    color: var(--white);
  }

  .prose :global(h3) {
    font-size: 19px;
    font-weight: 600;
    margin: 36px 0 12px;
    color: var(--white);
  }

  .prose :global(p) {
    font-size: 16px;
    color: var(--gray-300);
    line-height: 1.85;
    font-weight: 300;
    margin-bottom: 20px;
  }

  .prose :global(strong) {
    color: var(--white);
    font-weight: 600;
  }

  .prose :global(a) {
    color: var(--neon);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose :global(ul), .prose :global(ol) {
    margin: 0 0 20px 20px;
  }

  .prose :global(li) {
    font-size: 16px;
    color: var(--gray-300);
    line-height: 1.8;
    font-weight: 300;
    margin-bottom: 6px;
  }

  .prose :global(pre) {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px 24px;
    overflow-x: auto;
    margin: 24px 0;
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--gray-200);
  }

  .prose :global(p code), .prose :global(li code) {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 2px 6px;
    font-size: 13px;
    color: var(--neon);
  }

  .prose :global(blockquote) {
    border-left: 2px solid var(--neon);
    padding-left: 20px;
    margin: 28px 0;
  }

  .prose :global(blockquote p) {
    color: var(--gray-300);
    font-style: italic;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 40px 0;
  }

  .related {
    max-width: 720px;
    margin-bottom: 100px;
  }

  .related-label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--gray-500);
    letter-spacing: 2.5px;
    text-transform: uppercase;
    margin-bottom: 24px;
  }

  .related-posts {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .related-row {
    display: grid;
    grid-template-columns: 120px 1fr;
    align-items: center;
    gap: 24px;
    padding: 20px 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    transition: color 0.2s;
  }

  .related-row:first-child { border-top: 1px solid var(--border); }

  .related-date {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--gray-400);
    white-space: nowrap;
  }

  .related-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--white);
    transition: color 0.2s;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .related-row:hover .related-title { color: var(--neon); }
</style>

<div class="wrapper">

  <Nav />

  <a href="/blog" class="back-link">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M8.5 2.5L4 7L8.5 11.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Back to Blog
    </a>

  <div class="post-header">
    <h1>{post.data.title}</h1>
    <div class="post-meta">
      <div class="post-meta-row">
        <span class="post-date">{timeAgo(post.data.date)} | {formatDate(post.data.date)} | {readingTime} min read</span>
        {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
      <div class="author">
        <img class="author-avatar" src="/headshot.jpg" alt="Chase Brown" />
        <a class="author-name" href="https://www.linkedin.com/in/chase-brown-41a934173/" target="_blank" rel="noopener">Chase Brown</a>
      </div>
    </div>
  </div>

  <div class="divider"></div>

  <article class="prose">
    <Content />
  </article>

  {relatedPosts.length > 0 && (
    <div class="related">
      <div class="related-label">Related Posts</div>
      <div class="related-posts">
        {relatedPosts.map((p) => (
          <a href={`/blog/${p.id}`} class="related-row">
            <span class="related-date">{formatDate(p.data.date)}</span>
            <span class="related-title">{p.data.title}</span>
          </a>
        ))}
      </div>
    </div>
  )}

  <Footer />

</div>

</Layout>
