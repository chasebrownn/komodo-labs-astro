---
interface Props {
  tagline?: string;
}
const {
  tagline = "Whether you need an AI prototype, a smart contract audit, or end-to-end automation — let's talk.",
} = Astro.props;
---

<style>
  .cta { padding: 100px 0; text-align: center; }

  .cta-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 76px 48px;
    position: relative;
    overflow: hidden;
  }

  .cta-box::before {
    content: '';
    position: absolute;
    top: -100px;
    left: 50%;
    transform: translateX(-50%);
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(207,255,4,0.04) 0%, transparent 70%);
    pointer-events: none;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--gray-500);
    letter-spacing: 2.5px;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .cta-box h2 {
    font-size: 40px;
    font-weight: 700;
    margin-bottom: 16px;
    letter-spacing: -1px;
    position: relative;
  }

  .cta-box h2 span { color: var(--neon); }

  .cta-box p {
    font-size: 16px;
    color: var(--gray-400);
    max-width: 460px;
    margin: 0 auto 40px;
    line-height: 1.7;
    font-weight: 300;
    position: relative;
  }

  .cta-actions {
    display: flex;
    justify-content: center;
    gap: 14px;
    position: relative;
  }

  .btn {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 500;
    padding: 14px 32px;
    border-radius: 10px;
    border: none;
    cursor: pointer;
    transition: all 0.3s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
  }

  .btn-primary {
    background: var(--neon);
    color: var(--black);
    font-weight: 600;
  }

  .btn-primary:hover {
    box-shadow: 0 0 32px var(--neon-glow);
    transform: translateY(-2px);
  }

  .btn-secondary {
    background: var(--card);
    color: var(--gray-200);
    border: 1px solid var(--border);
  }

  .btn-secondary:hover {
    border-color: var(--border-hi);
    background: var(--card-hover);
    color: var(--white);
  }

  @media (max-width: 768px) {
    .cta-box { padding: 52px 24px; }
    .cta-actions { flex-direction: column; align-items: center; }
  }
</style>

<section class="cta" id="contact">
  <div class="cta-box">
    <div class="section-label">Let's build something</div>
    <h2>Ready to <span>ship</span>?</h2>
    <p>{tagline}</p>
    <div class="cta-actions">
      <a href="mailto:chase@komodolabs.io" class="btn btn-primary">Get in Touch</a>
      <a href={import.meta.env.PUBLIC_BOOKING_URL} target="_blank" rel="noopener" class="btn btn-secondary">Book a Call</a>
    </div>
  </div>
</section>
